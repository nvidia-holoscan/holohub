{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:holohub:application:v1",
  "type": "object",
  "required": [
    "application"
  ],
  "properties": {
    "application": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "urn:holohub:project:v1#/$defs/name"
        },
        "description": {
          "$ref": "urn:holohub:project:v1#/$defs/description"
        },
        "authors": {
          "$ref": "urn:holohub:project:v1#/$defs/authors"
        },
        "version": {
          "$ref": "urn:holohub:project:v1#/$defs/version"
        },
        "changelog": {
          "$ref": "urn:holohub:project:v1#/$defs/changelog"
        },
        "platforms": {
          "$ref": "urn:holohub:project:v1#/$defs/platforms"
        },
        "tags": {
          "$ref": "urn:holohub:project:v1#/$defs/tags"
        },
        "holoscan_sdk": {
          "$ref": "urn:holohub:project:v1#/$defs/sdk_version"
        },
        "ranking": {
          "$ref": "urn:holohub:project:v1#/$defs/ranking"
        },
        "requirements": {
          "$ref": "urn:holohub:project:v1#/$defs/requirements"
        },
        "dockerfile": {
          "type": "string"
        },
        "run": {
          "$ref": "urn:holohub:project:v1#/$defs/run_command"
        },
        "modes": {
          "$ref": "urn:holohub:project:v1#/$defs/modes"
        },
        "default_mode": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
          "description": "Name of the default mode to use when none is specified. Only needed when there are multiple modes."
        }
      },
      "required": [
        "name",
        "authors",
        "version",
        "changelog",
        "platforms",
        "tags",
        "holoscan_sdk",
        "ranking",
        "requirements"
      ],
      "allOf": [
        {
          "not": {
            "allOf": [
              {
                "required": [
                  "run"
                ]
              },
              {
                "required": [
                  "modes"
                ]
              }
            ]
          }
        }
      ],
      "if": {
        "required": [
          "modes"
        ],
        "properties": {
          "modes": {
            "minProperties": 2
          }
        }
      },
      "then": {
        "required": [
          "default_mode"
        ]
      }
    }
  }
}
