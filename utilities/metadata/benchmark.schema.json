{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:holohub:benchmark:v1",
  "type": "object",
  "properties": {
    "benchmark": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "urn:holohub:project:v1#/$defs/name"
        },
        "description": {
          "$ref": "urn:holohub:project:v1#/$defs/description"
        },
        "authors": {
          "$ref": "urn:holohub:project:v1#/$defs/authors"
        },
        "version": {
          "$ref": "urn:holohub:project:v1#/$defs/version"
        },
        "changelog": {
          "$ref": "urn:holohub:project:v1#/$defs/changelog"
        },
        "platforms": {
          "$ref": "urn:holohub:project:v1#/$defs/platforms"
        },
        "tags": {
          "$ref": "urn:holohub:project:v1#/$defs/tags"
        },
        "holoscan_sdk": {
          "$ref": "urn:holohub:project:v1#/$defs/sdk_version"
        },
        "ranking": {
          "$ref": "urn:holohub:project:v1#/$defs/ranking"
        },
        "requirements": {
          "$ref": "urn:holohub:project:v1#/$defs/requirements"
        },
        "dockerfile": {
          "type": "string"
        },
        "run": {
          "$ref": "urn:holohub:project:v1#/$defs/run_command"
        }
      },
      "required": [
        "name",
        "authors",
        "version",
        "platforms",
        "tags",
        "holoscan_sdk",
        "ranking",
        "requirements"
      ]
    }
  },
  "required": [
    "benchmark"
  ]
}
