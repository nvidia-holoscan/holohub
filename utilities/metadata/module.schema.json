{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:holohub:module:v2",
  "type": "object",
  "$defs": {
    "namespace": {
      "type": "object",
      "properties": {
        "cpp": {
          "type": "string"
        },
        "python": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "binary_packages": {
      "type": "object",
      "properties": {
        "debian": {
          "type": "string"
        },
        "pypi": {
          "type": "string"
        },
        "install_commands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Recommended shell commands to install this module's binary packages."
        }
      },
      "additionalProperties": false
    },
    "testing_block": {
      "type": "object",
      "properties": {
        "cpp": {
          "type": "string",
          "enum": [
            "ctest"
          ]
        },
        "python": {
          "type": "string",
          "enum": [
            "pytest"
          ]
        }
      },
      "additionalProperties": false
    },
    "documentation_block": {
      "type": "object",
      "description": "Paths used by the Holoscan documentation builder to locate this module's README and media assets.",
      "properties": {
        "readme": {
          "type": "string",
          "description": "Relative path from this metadata.json to the module README. Defaults to README.md in the same directory when absent."
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Relative paths to images, GIFs, or other assets the documentation builder must fetch for webpage rendering. Assumed relative to the project root."
        }
      },
      "additionalProperties": false
    },
    "quality_test_record": {
      "type": "object",
      "description": "A single test-result snapshot, typically populated by CI for one HSDK version and platform combination.",
      "properties": {
        "description": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "ISO 8601 date of the test run (e.g. '2026-05-01')."
        },
        "holoscan_sdk_version": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests_passing": {
          "type": "integer",
          "minimum": 0
        },
        "tests_failing": {
          "type": "integer",
          "minimum": 0
        },
        "code_coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "quality_reporting_block": {
      "type": "object",
      "properties": {
        "testing": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/quality_test_record"
          },
          "description": "Test-result records, one per HSDK version or test run. Populated by CI."
        },
        "quality_metric": {
          "type": "number",
          "minimum": 0,
          "maximum": 5,
          "description": "Self-reported quality score on a 0–5 scale."
        }
      },
      "additionalProperties": false
    },
    "dependency_source": {
      "type": "object",
      "description": "Source location for cmake-source resolution. Presence of this block signals that the HoloHub CLI will emit a FetchContent_Declare entry for this dependency and the HoloHub root CMakeLists.txt will FetchContent_MakeAvailable it at configure time when the dependency's operators are enabled. Other dependency kinds (binary packages, Python packages, etc.) are managed by their own tooling in the module's Dockerfile or setup scripts, not via this block.",
      "properties": {
        "git_url": {
          "type": "string"
        },
        "ref": {
          "type": "string",
          "description": "Git revision: commit SHA, tag, or branch. Commit SHAs are recommended for reproducibility; the resolver warns when ref looks like a moving target."
        }
      },
      "required": [
        "git_url",
        "ref"
      ],
      "additionalProperties": false
    },
    "module_dependency": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/dependency_source"
        },
        "provides_operators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Operators this dependency supplies to the consumer. The CLI resolver fetches this module only when at least one of these operators is in the set being built — letting consumers declare many module dependencies without paying the fetch cost for unused ones. The resolver validates this list against the module's own metadata.json:module.operators after fetch and warns on drift."
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": {
      "type": "string"
    },
    "module": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "urn:holohub:project:v1#/$defs/name"
        },
        "description": {
          "$ref": "urn:holohub:project:v1#/$defs/description"
        },
        "authors": {
          "$ref": "urn:holohub:project:v1#/$defs/authors"
        },
        "version": {
          "$ref": "urn:holohub:project:v1#/$defs/version"
        },
        "license": {
          "type": "string"
        },
        "language": {
          "$ref": "urn:holohub:project:v1#/$defs/multi_language"
        },
        "namespace": {
          "$ref": "#/$defs/namespace"
        },
        "platforms": {
          "$ref": "urn:holohub:project:v1#/$defs/platforms"
        },
        "tags": {
          "$ref": "urn:holohub:project:v1#/$defs/tags"
        },
        "holoscan_sdk": {
          "$ref": "urn:holohub:project:v1#/$defs/sdk_version"
        },
        "sensor_hardware": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Sensor or capture hardware this module supports (e.g. 'AJA KONA', 'Deltacast VideoMaster')."
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "URL of the module's primary landing page or repository."
        },
        "source_repository": {
          "type": "string"
        },
        "ranking": {
          "$ref": "urn:holohub:project:v1#/$defs/ranking"
        },
        "requirements": {
          "$ref": "urn:holohub:project:v1#/$defs/requirements"
        },
        "binary_packages": {
          "$ref": "#/$defs/binary_packages"
        },
        "testing": {
          "$ref": "#/$defs/testing_block"
        },
        "quality_reporting": {
          "$ref": "#/$defs/quality_reporting_block"
        },
        "dockerfile": {
          "type": "string"
        },
        "documentation": {
          "$ref": "#/$defs/documentation_block"
        },
        "subprojects": {
          "type": "object",
          "properties": {
            "operators": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "applications": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        },
        "operators": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Operators this module supplies. Authoritative self-advertisement; consumers may mirror these in their dependencies[].provides_operators to enable lazy fetch. The resolver compares the two lists after fetch and warns on drift."
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/module_dependency"
          }
        }
      },
      "required": [
        "name",
        "description",
        "authors",
        "version",
        "language",
        "platforms",
        "tags",
        "holoscan_sdk"
      ]
    }
  },
  "required": [
    "module"
  ]
}
