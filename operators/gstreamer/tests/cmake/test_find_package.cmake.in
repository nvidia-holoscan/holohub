#
# CMake project-mode test: verifies find_package(holoscan-gstreamer) succeeds from
# the build tree and that the imported target is available.  Configured into a
# standalone CMakeLists.txt and run via ctest in project mode (not script mode),
# because the generated targets file calls add_library() which is not scriptable.

cmake_minimum_required(VERSION 3.20)
project(test_find_package LANGUAGES NONE)

set(holoscan-gstreamer_DIR "@CMAKE_CURRENT_BINARY_DIR@")
find_package(holoscan-gstreamer REQUIRED NO_DEFAULT_PATH)

if(NOT TARGET holoscan::holoscan_gstreamer_bridge)
    message(FATAL_ERROR
        "find_package(holoscan-gstreamer) succeeded but target "
        "holoscan::holoscan_gstreamer_bridge was not defined. "
        "Check that the targets file was generated correctly.")
endif()

message(STATUS "PASS: find_package(holoscan-gstreamer) with holoscan-gstreamer_DIR=${holoscan-gstreamer_DIR} OK; "
               "target holoscan::holoscan_gstreamer_bridge is available")
