# Doxygen configuration for HoloHub operator C++ API reference generation.
# This generates XML output consumed by generate_api_docs.py to produce
# Markdown API reference sections for operator documentation pages.

PROJECT_NAME           = "HoloHub Operators"
OUTPUT_DIRECTORY       = _build/doxygen

# Input: all operator headers
INPUT                  = ../../operators
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.h
EXCLUDE_PATTERNS       = *pydoc* */test/* */tests/* *_test.* */build/*

# Only generate XML (consumed by generate_api_docs.py)
GENERATE_XML           = YES
GENERATE_HTML          = NO
GENERATE_LATEX         = NO
XML_OUTPUT             = xml
XML_PROGRAMLISTING     = NO

# Extraction settings
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = HOLOSCAN_OPERATOR_FORWARD_ARGS(x)= \
                         HOLOSCAN_OPERATOR_FORWARD_ARGS_SUPER(x,y)=

# Suppress verbose progress output but keep warnings so parse errors are visible.
# Warnings are redirected to a log file rather than stderr to keep CI output clean.
QUIET                  = YES
WARNINGS               = YES
WARN_LOGFILE           = _build/doxygen/warnings.log

# Source browsing (not needed for XML-only)
SOURCE_BROWSER         = NO
VERBATIM_HEADERS       = NO
