# HoloHub source-project entry point. Delegates to the standalone
# `holoscan-cli` package (https://github.com/nvidia-holoscan/holoscan-cli),
# defaulting to NVIDIA PyPI release-candidate-capable install args.
#
# Optional overrides (rarely needed):
#   HOLOSCAN_CLI_SOURCE   Local checkout — wins over the package install.
#   HOLOSCAN_CLI_INSTALL_ARGS  Pip install arguments.
#   HOLOSCAN_CLI_PYTHON_BIN  Interpreter for the CLI (default: a user-owned managed venv).
#   HOLOSCAN_CLI_VENV        Location of the managed CLI venv (default under XDG data dir).
#   HOLOSCAN_CLI_CTEST_SCRIPT  CTest script used by `./holohub test`.
#   HOLOHUB_PYTHON_BIN       Legacy fallback for HOLOSCAN_CLI_PYTHON_BIN.
#
# The CLI itself installs into a user-owned venv (never system Python, never as
# root), and `setup` uses sudo only for the host packages/files it installs.
# Applications run unprivileged by default, but some hardware apps document
# running with elevated privileges (e.g. `sudo ./holohub run ...`, setcap,
# sysctl) for raw network, real-time scheduling, or device access -- so the
# wrapper permits root: it warns when provisioning as root, but never blocks.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
export HOLOSCAN_CLI_CMD_NAME="${BASH_SOURCE[0]}"
export HOLOSCAN_CLI_ROOT="${SCRIPT_DIR}"

export HOLOSCAN_CLI_INSTALL_ARGS="${HOLOSCAN_CLI_INSTALL_ARGS:---pre --extra-index-url https://pypi.nvidia.com holoscan-cli>4.2.0}"
HOLOSCAN_CLI_VENV="${HOLOSCAN_CLI_VENV:-${XDG_DATA_HOME:-$HOME/.local/share}/holoscan-cli/venv}"

# Default Holoscan SDK version for project container base images. holoscan-cli
# decoupled the base image from its own version (holoscan-cli#177) and no longer
# ships a built-in default, so it errors unless this is set (or --base-img is
# passed). Pin it here -- this is the single source of truth that replaces the
# former in-tree CLI's util.py DEFAULT_BASE_SDK_VERSION (holohub#1590). Env var
# takes precedence; per-project scripts may still override via export.
export HOLOSCAN_CLI_BASE_SDK_VERSION="${HOLOSCAN_CLI_BASE_SDK_VERSION:-4.3.0}"
export HOLOSCAN_CLI_CTEST_SCRIPT="${HOLOSCAN_CLI_CTEST_SCRIPT:-utilities/testing/holohub.container.ctest}"

# Probe the command surface (not just importability), so a stale legacy
# holoscan-cli (<= 4.2.0, which lacks `build`/`list`) doesn't satisfy the check.
_holoscan_cli_ok() { "$1" -m holoscan_cli --help 2>/dev/null | grep -qw build; }

# A local holoscan-cli checkout takes precedence and needs no install.
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    export PYTHONPATH="${HOLOSCAN_CLI_SOURCE%/}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

# Resolve the interpreter that runs the CLI, in order:
#   1. An explicit choice: HOLOSCAN_CLI_PYTHON_BIN / legacy var / an active venv.
#   2. The managed venv whenever it exists -- it is the CLI's home; if its CLI
#      is stale or broken, the install step below repairs it in place.
#   3. python3 when the CLI is already installed there (container images, global
#      installs). Skipped for source checkouts, whose pip/setup installs must
#      land in a venv rather than a possibly externally-managed system Python.
#   4. Otherwise create the managed venv (one-time; also re-runs over a venv
#      whose python was broken by a system Python upgrade).
if [[ -n "${HOLOSCAN_CLI_PYTHON_BIN:-}${HOLOHUB_PYTHON_BIN:-}${VIRTUAL_ENV:-}" ]]; then
    PYTHON_BIN="${HOLOSCAN_CLI_PYTHON_BIN:-${HOLOHUB_PYTHON_BIN:-${VIRTUAL_ENV:+$VIRTUAL_ENV/bin/python}}}"
    PYTHON_BIN="${PYTHON_BIN:-python3}"
elif [[ -x "${HOLOSCAN_CLI_VENV}/bin/python" ]]; then
    PYTHON_BIN="${HOLOSCAN_CLI_VENV}/bin/python"
elif [[ -z "${HOLOSCAN_CLI_SOURCE:-}" ]] && _holoscan_cli_ok python3; then
    PYTHON_BIN="python3"
else
    # One-time provisioning. sudo isn't needed for this (setup elevates apt
    # itself); as root it still works but leaves root-owned files under $HOME.
    if [[ "${EUID}" -eq 0 ]]; then
        echo "[holohub] Note: sudo isn't needed (setup elevates apt itself), and running as root" \
             "creates root-owned files under \$HOME. Continuing anyway." >&2
    fi
    python3 -m venv "${HOLOSCAN_CLI_VENV}" || {
        echo "[holohub] Could not create ${HOLOSCAN_CLI_VENV}." \
             "Install venv once:  sudo apt install python3-venv  then re-run ./holohub." >&2
        exit 1
    }
    PYTHON_BIN="${HOLOSCAN_CLI_VENV}/bin/python"
fi
export HOLOSCAN_CLI_PYTHON_BIN="${PYTHON_BIN}"

# Setup scripts historically invoke `python3 -m pip`. Put the selected
# interpreter first on PATH so those scripts use the same environment as the
# CLI, including when the wrapper created the managed venv.
PYTHON_PATH="$(command -v "${PYTHON_BIN}" 2>/dev/null || true)"
if [[ -n "${PYTHON_PATH}" ]]; then
    export PATH="$(dirname "${PYTHON_PATH}"):${PATH}"
fi

# Install the CLI into the resolved interpreter if it isn't already usable there
# (a source checkout on PYTHONPATH, a container image, or a prior install all
# satisfy the probe, so this is a no-op on every run after the first).
if _holoscan_cli_ok "${PYTHON_BIN}"; then
    :  # already usable -- nothing to install
else
    # Ensure the chosen interpreter has pip before installing. The managed venv
    # always has it, but an explicitly selected interpreter (HOLOSCAN_CLI_PYTHON_BIN
    # / HOLOHUB_PYTHON_BIN / VIRTUAL_ENV) on a minimal Python may not -- bootstrap
    # it, or fail clearly instead of a confusing "No module named pip".
    if ! "${PYTHON_BIN}" -m pip --version >/dev/null 2>&1; then
        "${PYTHON_BIN}" -m ensurepip --upgrade >/dev/null 2>&1 || {
            echo "[holohub] ${PYTHON_BIN} has no pip and ensurepip is unavailable;" \
                 "install pip, or point HOLOSCAN_CLI_PYTHON_BIN at an interpreter that has it." >&2
            exit 1
        }
    fi
    if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
        echo "[holohub] installing holoscan-cli from ${HOLOSCAN_CLI_SOURCE}" >&2
        "${PYTHON_BIN}" -m pip install --upgrade "${HOLOSCAN_CLI_SOURCE}"
    elif "${PYTHON_BIN}" -m pip install ${HOLOSCAN_CLI_INSTALL_ARGS}; then
        :
    else
        echo "[holohub] Could not install holoscan-cli into ${PYTHON_BIN}." >&2
        echo "[holohub] On a PEP 668 system Python, create a venv first:" >&2
        echo "[holohub]   python3 -m venv .venv && source .venv/bin/activate && ./holohub setup" >&2
        echo "[holohub] Or build/run in the container, which manages Python for you." >&2
        exit 1
    fi
fi

# Forward the package install args (and any local source) as `--build-arg`s on every
# project `docker build` so the in-container CLI matches the host. holoscan-cli
# shlex-splits HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS, so single-quote each
# KEY=VALUE to survive values with spaces and single quotes.
_q() {
    local value="${1//\'/\'\"\'\"\'}"
    printf "'%s'" "${value}"
}
extras=" --build-arg $(_q "HOLOSCAN_CLI_INSTALL_ARGS=${HOLOSCAN_CLI_INSTALL_ARGS}")"
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    extras+=" --build-context $(_q "holoscan-cli-src=${HOLOSCAN_CLI_SOURCE}")"
fi
export HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS="${HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS:-}${extras}"

exec "${PYTHON_BIN}" -m holoscan_cli "$@"
