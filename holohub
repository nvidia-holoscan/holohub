#
# HoloHub source-project entry point. Delegates to the standalone
# `holoscan-cli` package (https://github.com/nvidia-holoscan/holoscan-cli).
#
# Configuration:
#   HOLOSCAN_CLI_*       Environment variables consumed by the CLI; see the
#                        holoscan-cli docs (`holoscan env-info`) for the full
#                        surface.
#
# Bootstrap (install on first run):
#   HOLOSCAN_CLI_SOURCE  Local holoscan-cli checkout. Takes precedence.
#   HOLOSCAN_CLI_VERSION Pip install spec. Defaults to `holoscan-cli` (latest
#                        on PyPI). Examples: `holoscan-cli==4.3.0`, `>=4.3`,
#                        `git+https://github.com/nvidia-holoscan/holoscan-cli.git@main`.
#   HOLOHUB_PYTHON_BIN   Override the Python interpreter (default: python3).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
export HOLOSCAN_CLI_CMD_NAME="${BASH_SOURCE[0]}"
export HOLOSCAN_CLI_ROOT="${SCRIPT_DIR}"

PYTHON_BIN="${HOLOHUB_PYTHON_BIN:-python3}"

if ! "${PYTHON_BIN}" -c 'import holoscan_cli' &>/dev/null; then
    spec="${HOLOSCAN_CLI_SOURCE:-${HOLOSCAN_CLI_VERSION:-holoscan-cli}}"
    echo "[holohub] installing ${spec}" >&2
    "${PYTHON_BIN}" -m pip install "${spec}"
fi

if command -v holoscan >/dev/null 2>&1; then
    exec holoscan "$@"
fi
exec "${PYTHON_BIN}" -m holoscan_cli "$@"
