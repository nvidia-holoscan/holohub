# HoloHub source-project entry point. Delegates to the standalone
# `holoscan-cli` package (https://github.com/nvidia-holoscan/holoscan-cli),
# pinned to a specific TestPyPI build during the consolidation rollout so
# every invocation gets the same CLI regardless of what's cached locally.
#
# Optional overrides (rarely needed):
#   HOLOSCAN_CLI_SOURCE   Local checkout — wins over the pin.
#   HOLOSCAN_CLI_VERSION  Pip install spec.
#   HOLOHUB_PYTHON_BIN    Python interpreter (default: python3).

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
export HOLOSCAN_CLI_CMD_NAME="${BASH_SOURCE[0]}"
export HOLOSCAN_CLI_ROOT="${SCRIPT_DIR}"

PYTHON_BIN="${HOLOHUB_PYTHON_BIN:-python3}"

# Pinned consolidated holoscan-cli during the rollout. Env vars take
# precedence so users can opt into a different version without editing.
export HOLOSCAN_CLI_VERSION="${HOLOSCAN_CLI_VERSION:-holoscan-cli==4.3.0a26390596878}"

# A local holoscan-cli checkout takes precedence over the pinned install.
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    export PYTHONPATH="${HOLOSCAN_CLI_SOURCE%/}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

# Bootstrap if the consolidated CLI isn't importable. Two-step install (matches
# CI) keeps TestPyPI scoped to the holoscan-cli wheel so a TestPyPI mirror of a
# common dep can't shadow the PyPI one.
if ! "${PYTHON_BIN}" -c "import holoscan_cli.__main__" &>/dev/null; then
    if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
        echo "[holohub] installing holoscan-cli from ${HOLOSCAN_CLI_SOURCE}" >&2
        "${PYTHON_BIN}" -m pip install --upgrade "${HOLOSCAN_CLI_SOURCE}"
    else
        echo "[holohub] installing ${HOLOSCAN_CLI_VERSION}" >&2
        "${PYTHON_BIN}" -m pip install --pre --no-deps \
            --index-url https://test.pypi.org/simple/ "${HOLOSCAN_CLI_VERSION}"
        "${PYTHON_BIN}" -m pip install \
            --index-url https://pypi.org/simple/ "${HOLOSCAN_CLI_VERSION}"
    fi
fi

# Forward the pinned spec (and any local source) as `--build-arg`s on every
# project `docker build` so the in-container CLI matches the host. holoscan-cli
# shlex-splits HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS, so single-quote each
# KEY=VALUE to survive values with spaces.
_q() { printf "'%s'" "${1//\'/\'\\\'\'}"; }
extras=" --build-arg $(_q "HOLOSCAN_CLI_INSTALL_SPEC=${HOLOSCAN_CLI_VERSION}")"
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    extras+=" --build-context $(_q "holoscan-cli-src=${HOLOSCAN_CLI_SOURCE}")"
fi
export HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS="${HOLOSCAN_CLI_DEFAULT_DOCKER_BUILD_ARGS:-}${extras}"

exec "${PYTHON_BIN}" -m holoscan_cli "$@"
