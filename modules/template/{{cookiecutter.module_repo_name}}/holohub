#
# {{ cookiecutter.project_name }} CLI wrapper.
# Delegates to the standalone `holoscan-cli` package with module-specific
# defaults baked in. On first run, installs holoscan-cli via pip if it isn't
# already importable.
#
# Usage:
#   ./holohub run-container
#   ./holohub build {{ cookiecutter.module_slug }}_pipeline
#   ./holohub run   {{ cookiecutter.module_slug }}_pipeline --language python
#   ./holohub --help
#
# Bootstrap (install on first run):
#   HOLOSCAN_CLI_SOURCE  Local holoscan-cli checkout. Takes precedence.
#   HOLOSCAN_CLI_VERSION Pip install spec. Defaults to `holoscan-cli` (latest
#                        on PyPI). Examples: `holoscan-cli==4.3.0`, `>=4.3`,
#                        `git+https://github.com/nvidia-holoscan/holoscan-cli.git@main`.
#   HOLOHUB_PYTHON_BIN   Override the Python interpreter (default: python3).

set -euo pipefail

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

# ==============================================================================
# Module identity — defaults consumed by the consolidated holoscan-cli
# ==============================================================================

# HOLOSCAN_CLI_ROOT: the CLI uses this as the project root for cmake -S and container paths.
export HOLOSCAN_CLI_ROOT="${HOLOSCAN_CLI_ROOT:-${SCRIPT_DIR}}"
# HOLOSCAN_CLI_CMD_NAME: shown in help output and error messages.
export HOLOSCAN_CLI_CMD_NAME="${HOLOSCAN_CLI_CMD_NAME:-${BASH_SOURCE[0]}}"
# HOLOSCAN_CLI_REPO_PREFIX: base for naming build dirs, images, etc.
export HOLOSCAN_CLI_REPO_PREFIX="${HOLOSCAN_CLI_REPO_PREFIX:-{{ cookiecutter.module_slug }}}"
# HOLOSCAN_CLI_CONTAINER_PREFIX: Docker image name prefix.
export HOLOSCAN_CLI_CONTAINER_PREFIX="${HOLOSCAN_CLI_CONTAINER_PREFIX:-{{ cookiecutter.module_slug.replace('_', '-') }}}"
# HOLOSCAN_CLI_WORKSPACE_NAME: directory name inside the container at /workspace/.
export HOLOSCAN_CLI_WORKSPACE_NAME="${HOLOSCAN_CLI_WORKSPACE_NAME:-{{ cookiecutter.module_slug }}}"
# HOLOSCAN_CLI_HOSTNAME_PREFIX: container hostname prefix.
export HOLOSCAN_CLI_HOSTNAME_PREFIX="${HOLOSCAN_CLI_HOSTNAME_PREFIX:-{{ cookiecutter.module_slug.replace('_', '-') }}}"

# ==============================================================================
# Paths
# ==============================================================================

export HOLOSCAN_CLI_DEFAULT_DOCKERFILE="${HOLOSCAN_CLI_DEFAULT_DOCKERFILE:-${SCRIPT_DIR}/Dockerfile}"
export HOLOSCAN_CLI_SEARCH_PATH="${HOLOSCAN_CLI_SEARCH_PATH:-${SCRIPT_DIR}/applications,${SCRIPT_DIR}/operators}"
export HOLOSCAN_CLI_BUILD_PARENT_DIR="${HOLOSCAN_CLI_BUILD_PARENT_DIR:-${SCRIPT_DIR}/build}"
export HOLOSCAN_CLI_DATA_DIR="${HOLOSCAN_CLI_DATA_DIR:-${SCRIPT_DIR}/data}"

# ==============================================================================
# Build defaults
# ==============================================================================

export CMAKE_BUILD_TYPE="${CMAKE_BUILD_TYPE:-Release}"

# ==============================================================================
# Bootstrap holoscan-cli + exec
# ==============================================================================

PYTHON_BIN="${HOLOHUB_PYTHON_BIN:-python3}"

if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    export PYTHONPATH="${HOLOSCAN_CLI_SOURCE%/}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

# Require a *consolidated* holoscan-cli (exposes PROJECT_COMMANDS). Older
# releases import cleanly but lack the source-project dispatch table this
# wrapper depends on, so reinstall/upgrade when the feature check fails.
_holohub_cli_has_consolidated_dispatch() {
    "${PYTHON_BIN}" - <<'PY' &>/dev/null
from holoscan_cli.__main__ import PROJECT_COMMANDS

required = {"build", "run", "list", "install"}
assert required <= set(PROJECT_COMMANDS), f"missing: {required - set(PROJECT_COMMANDS)}"
PY
}

if ! _holohub_cli_has_consolidated_dispatch; then
    spec="${HOLOSCAN_CLI_SOURCE:-${HOLOSCAN_CLI_VERSION:-holoscan-cli}}"
    echo "[{{ cookiecutter.module_slug }}] installing/upgrading ${spec}" >&2
    "${PYTHON_BIN}" -m pip install --upgrade "${spec}"
fi

# exec replaces the shell so SIGINT/SIGTERM/SIGHUP reach the CLI directly.
# Prefer the installed `holoscan` binary when it's the consolidated CLI, but
# fall through to `python -m holoscan_cli` if PATH resolves to the legacy
# packaging-only `holoscan` shipped with the Holoscan SDK Python package
# (whose subcommand set is just package/run/version/nics).
_holohub_holoscan_is_consolidated() {
    "${1}" --help 2>/dev/null | grep -qE '^\s*list\s'
}

holoscan_bin="$(command -v holoscan 2>/dev/null || true)"
if [[ -n "${holoscan_bin}" ]] && _holohub_holoscan_is_consolidated "${holoscan_bin}"; then
    exec "${holoscan_bin}" "$@"
fi
exec "${PYTHON_BIN}" -m holoscan_cli "$@"
