# ==============================================================================
# HoloHub CLI Wrapper — external-application example
# ==============================================================================
#
# DESCRIPTION:
#   Minimal wrapper that delegates to the packaged ``holoscan-cli`` published
#   on PyPI. Previous revisions of this script sparse-checked-out HoloHub's
#   ``utilities/cli/`` to run an inline copy of the CLI; the CLI now lives in
#   the standalone ``holoscan-cli`` package and HoloHub itself is one of its
#   downstream consumers, so external apps wanting a wrapper only need to
#   install the package and invoke it.
#
# USAGE:
#   ./holohubCLI_wrapper [CLI_OPTIONS]
#
# ENVIRONMENT VARIABLES:
#   HOLOSCAN_CLI_SOURCE   Path to a local holoscan-cli checkout (used during
#                         prototype iteration). Wins over HOLOSCAN_CLI_VERSION.
#   HOLOSCAN_CLI_VERSION  Pip install spec for holoscan-cli. Bare versions
#                         and operator-prefixed values are normalized to
#                         include the package name. Examples:
#                           HOLOSCAN_CLI_VERSION=4.3.0
#                             -> pip install holoscan-cli==4.3.0
#                           HOLOSCAN_CLI_VERSION=">=4.3"
#                             -> pip install holoscan-cli>=4.3
#                           HOLOSCAN_CLI_VERSION=holoscan-cli==4.3.0
#                             -> passed through unchanged
#                         Defaults to ``holoscan-cli`` (latest on PyPI).
#   HOLOSCAN_CLI_PYTHON_BIN  Override the Python interpreter used to install
#                            and invoke the CLI (default: ``python3``).
#
# EXAMPLES:
#   ./holohubCLI_wrapper --help
#   HOLOSCAN_CLI_VERSION=">=4.3" ./holohubCLI_wrapper list
#   HOLOSCAN_CLI_SOURCE=$HOME/src/holoscan-cli ./holohubCLI_wrapper run my_app
# ==============================================================================

set -euo pipefail

# Export the wrapper's own directory as the source-project root so that
# invoking this script from any working directory still operates on the
# external project this wrapper ships with. Mirrors the repo-root
# `./holohub` wrapper — `python -m holoscan_cli` otherwise falls back to
# the caller's cwd, which scans/builds the wrong tree when users copy
# this wrapper into their own project and invoke it from elsewhere.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
export HOLOSCAN_CLI_CMD_NAME="${BASH_SOURCE[0]}"
export HOLOSCAN_CLI_ROOT="${SCRIPT_DIR}"

PYTHON_BIN="${HOLOSCAN_CLI_PYTHON_BIN:-python3}"

# When the user points at a local holoscan-cli checkout, the source-tree
# version must win over any system-installed copy — both the dispatch
# probe below and the final `python -m holoscan_cli` invocation. Prepend
# `<source>/src` to PYTHONPATH so import resolution picks up the
# checkout first. Mirrors the repo-root `./holohub` wrapper's behavior.
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    export PYTHONPATH="${HOLOSCAN_CLI_SOURCE%/}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

_holoscan_cli_has_source_project_dispatch() {
    "${PYTHON_BIN}" - <<'PY' >/dev/null 2>&1
from holoscan_cli.__main__ import PROJECT_COMMANDS

required = {"build", "run", "list", "install"}
assert required <= set(PROJECT_COMMANDS), f"missing: {required - set(PROJECT_COMMANDS)}"
PY
}

_holohub_normalize_cli_spec() {
    local raw="$1"
    case "${raw}" in
        holoscan-cli|holoscan-cli[\<\>=\!~]*|holoscan_cli|holoscan_cli[\<\>=\!~]*)
            printf '%s' "${raw}" ;;
        *://*|/*|./*|.|git+*|file:*)
            printf '%s' "${raw}" ;;
        [\<\>=\!~]*)
            printf 'holoscan-cli%s' "${raw}" ;;
        [0-9]*)
            printf 'holoscan-cli==%s' "${raw}" ;;
        *)
            printf '%s' "${raw}" ;;
    esac
}

_install_holoscan_cli() {
    local spec
    if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
        spec="${HOLOSCAN_CLI_SOURCE}"
        echo "[holohubCLI_wrapper] installing holoscan-cli from local source: ${spec}" >&2
    else
        spec="$(_holohub_normalize_cli_spec "${HOLOSCAN_CLI_VERSION:-holoscan-cli}")"
        echo "[holohubCLI_wrapper] installing ${spec}" >&2
    fi
    "${PYTHON_BIN}" -m pip install --quiet --upgrade "${spec}"
}

if ! _holoscan_cli_has_source_project_dispatch; then
    _install_holoscan_cli
fi

exec "${PYTHON_BIN}" -m holoscan_cli "$@"
