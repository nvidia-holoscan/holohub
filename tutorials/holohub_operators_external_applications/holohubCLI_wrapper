# ==============================================================================
# HoloHub CLI wrapper — external-application example
# ==============================================================================
# Minimal wrapper that installs (if needed) and delegates to the standalone
# `holoscan-cli` package. Copy it into an external project to drive
# HoloHub-style build/run from there.
#
# Env vars:
#   HOLOSCAN_CLI_SOURCE      Local holoscan-cli checkout; wins over _VERSION.
#   HOLOSCAN_CLI_VERSION     Pip spec (bare versions/operators normalized to
#                            `holoscan-cli`). Default: `holoscan-cli` (PyPI).
#   HOLOSCAN_CLI_BASE_SDK_VERSION
#                            Holoscan SDK version for container base images
#                            (required by run/build/package). Default: 4.3.0.
#   HOLOSCAN_CLI_PYTHON_BIN  Python interpreter (default: python3).
#
# Examples:
#   ./holohubCLI_wrapper --help
#   HOLOSCAN_CLI_VERSION=">=4.3" ./holohubCLI_wrapper list
# ==============================================================================

set -euo pipefail

# Pin the source-project root to this script's directory so it works from any
# cwd (otherwise `python -m holoscan_cli` scans the caller's cwd and builds the
# wrong tree). Mirrors the repo-root `./holohub` wrapper.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
export HOLOSCAN_CLI_CMD_NAME="${BASH_SOURCE[0]}"
export HOLOSCAN_CLI_ROOT="${SCRIPT_DIR}"

# Default Holoscan SDK version for project container base images. Recent
# holoscan-cli releases decoupled the base image from the CLI version and no
# longer ship a built-in default, so `run`/`build`/`package` error out unless
# this is set (or `--base-img` is passed). Override to match the SDK your
# external project targets. Env var takes precedence.
export HOLOSCAN_CLI_BASE_SDK_VERSION="${HOLOSCAN_CLI_BASE_SDK_VERSION:-4.3.0}"

PYTHON_BIN="${HOLOSCAN_CLI_PYTHON_BIN:-python3}"

# Make a HOLOSCAN_CLI_SOURCE checkout win over any system-installed copy by
# prepending `<source>/src` to PYTHONPATH. Mirrors the repo-root wrapper.
if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
    export PYTHONPATH="${HOLOSCAN_CLI_SOURCE%/}/src${PYTHONPATH:+:${PYTHONPATH}}"
fi

_holoscan_cli_has_source_project_dispatch() {
    # Probe the public `holoscan --help` surface (same interpreter, so a
    # PYTHONPATH checkout wins) for a source-project command only the
    # consolidated CLI has.
    "${PYTHON_BIN}" -m holoscan_cli --help 2>/dev/null | grep -qw build
}

_holohub_normalize_cli_spec() {
    local raw="$1"
    case "${raw}" in
        holoscan-cli|holoscan-cli[\<\>=\!~]*|holoscan_cli|holoscan_cli[\<\>=\!~]*)
            printf '%s' "${raw}" ;;
        *://*|/*|./*|.|git+*|file:*)
            printf '%s' "${raw}" ;;
        [\<\>=\!~]*)
            printf 'holoscan-cli%s' "${raw}" ;;
        [0-9]*)
            printf 'holoscan-cli==%s' "${raw}" ;;
        *)
            printf '%s' "${raw}" ;;
    esac
}

_install_holoscan_cli() {
    local spec
    if [[ -n "${HOLOSCAN_CLI_SOURCE:-}" ]]; then
        spec="${HOLOSCAN_CLI_SOURCE}"
        echo "[holohubCLI_wrapper] installing holoscan-cli from local source: ${spec}" >&2
    else
        spec="$(_holohub_normalize_cli_spec "${HOLOSCAN_CLI_VERSION:-holoscan-cli}")"
        echo "[holohubCLI_wrapper] installing ${spec}" >&2
    fi
    "${PYTHON_BIN}" -m pip install --quiet --upgrade "${spec}"
}

if ! _holoscan_cli_has_source_project_dispatch; then
    _install_holoscan_cli
fi

exec "${PYTHON_BIN}" -m holoscan_cli "$@"
