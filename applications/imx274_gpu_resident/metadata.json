{
	"application": {
		"name": "IMX274 GPU-Resident",
		"authors": [
			{
				"name": "Holoscan Team",
				"affiliation": "NVIDIA"
			}
		],
		"language": "C++",
		"version": "1.0",
		"changelog": {
			"1.0": "Initial Release"
		},
		"dockerfile": "applications/imx274_gpu_resident/Dockerfile",
		"holoscan_sdk": {
			"minimum_required_version": "4.0.0",
			"tested_versions": [
				"4.0.0"
			]
		},
		"platforms": [
			"aarch64"
		],
		"tags": [
			"Holoscan Sensor Bridge",
			"Hololink",
			"Camera",
			"IMX274",
			"GPU Resident",
			"RDMA",
			"Deterministic",
			"Predictable",
			"Low-jitter",
			"DOCA GPUNetIO"
		],
		"ranking": 2,
		"requirements": {
			"hardware": [
				{
					"name": "IMX274 camera with Holoscan Sensor Bridge and Holoscan SDK GPU-resident Execution",
					"description": "Requires an IMX274 camera connected via a Holoscan Sensor Bridge device.",
					"required": true
				}
			]
		},
		"default_mode": "default",
		"modes": {
			"default": {
				"description": "Run with IMX274 camera with Holoscan Sensor Bridge",
				"run": {
					"command": "<holohub_app_bin>/cpp/imx274_gpu_resident",
					"workdir": "holohub_bin",
					"docker_run_args": [
						"-u",
						"root",
						"--shm-size=1gb",
						"--privileged",
						"-v",
						"/sys/bus/pci/devices:/sys/bus/pci/devices",
						"-v",
						"/sys/kernel/mm/hugepages:/sys/kernel/mm/hugepages",
						"-v",
						"/tmp/argus_socket:/tmp/argus_socket",
						"-v",
						"/sys/devices:/sys/devices",
						"-v",
						"/var/nvidia/nvcam/settings:/var/nvidia/nvcam/settings",
						"-e",
						"enableRawReprocess=2",
						"-e",
						"DISPLAY="
					]
				}
			},
			"doca": {
				"description": "Build and run with DOCA SDK and GPUNetIO for GPU-side RoCE CQ polling",
				"build": {
					"docker_build_args": [
						"--build-arg",
						"INSTALL_DOCA=1"
					],
					"cmake_options": [
						"-DHOLOHUB_ENABLE_DOCA_GPUNETIO=ON"
					]
				},
				"run": {
					"command": "<holohub_app_bin>/cpp/imx274_gpu_resident --docagpunetio",
					"workdir": "holohub_bin",
					"docker_run_args": [
						"-u",
						"root",
						"--shm-size=1gb",
						"--privileged",
						"-v",
						"/sys/bus/pci/devices:/sys/bus/pci/devices",
						"-v",
						"/sys/kernel/mm/hugepages:/sys/kernel/mm/hugepages",
						"-v",
						"/tmp/argus_socket:/tmp/argus_socket",
						"-v",
						"/sys/devices:/sys/devices",
						"-v",
						"/var/nvidia/nvcam/settings:/var/nvidia/nvcam/settings",
						"-e",
						"enableRawReprocess=2",
						"-e",
						"DISPLAY="
					]
				}
			}
		}
	}
}
