// IMX274 GPU-Resident Application Architecture
// NVIDIA theme. Render with: dot -Tpng -o imx274_gpu_resident_architecture.png imx274_gpu_resident_architecture.dot
digraph imx274_gpu_resident_arch {
    // NVIDIA theme. CPU left, GPU right, both vertical.
    graph [fontname = "Arial"; fontsize = "12"; splines = "true"; nodesep = "0.4"; ranksep = "0.6"; bgcolor = "#f7f7f7"; label = "IMX274 GPU-Resident Application"; labelloc = "t"; fontsize = "14"; newrank = true;];
    
    node [fontname = "Arial"; fontsize = "11"; shape = "box"; style = "rounded,filled";];
    
    edge [fontname = "Arial"; fontsize = "10";];
    
    // ========== CPU: Receiver Fragment + cuDisp present thread ==========
    subgraph cluster_cpu {
        label = "CPU";
        labelloc = "t";
        style = "rounded,filled";
        fillcolor = "#e8e8e8";
        color = "#76B900";
        penwidth = "2";
        fontname = "Arial Bold";
        fontsize = "18";
        labeljust = "l";
        
        RoceReceiverOp [label = <
            <table border="1" cellborder="1" cellspacing="0" cellpadding="6" bgcolor="#d4e6c3" color="#76B900">
            <tr><td colspan="2" align="center"><b>RoceReceiverOp</b><br/>(skip_host_metadata)</td></tr>
            <tr><td bgcolor="#fff9e6"><font point-size="9">CX7</font></td><td bgcolor="#fff9e6"><font point-size="9">CQ/QP ack only</font></td></tr>
            </table>
            >;shape = "plain";];
        PresentThread [label = <cuDisp present thread<br/>triggers display flip>;shape = "box";style = "rounded,filled";fillcolor = "#e6f0ff";color = "#76B900";fontsize = "10";];
    }
    
    // ========== GPU: GPU-Resident Fragment ==========
    subgraph cluster_gpu {
        label = "GPU";
        labelloc = "t";
        style = "rounded,filled";
        fillcolor = "#d4e6c3";
        color = "#76B900";
        penwidth = "2";
        fontname = "Arial Bold";
        fontsize = "18";
        labeljust = "l";
        
        subgraph cluster_gr_fragment {
            label = "GPU-Resident Fragment";
            style = "rounded,filled";
            fillcolor = "#e8e8e8";
            color = "#76B900";
            penwidth = "1";
            fontsize = "12";
            
            // Data Ready Fragment - checks metadata
            subgraph cluster_data_ready {
                label = "Data Ready Handler";
                style = "rounded,filled";
                fillcolor = "#e6f0ff";
                color = "#76B900";
                penwidth = "1";
                fontsize = "10";
                
                DataReadyInputOp [label = "DataReadyInputOp\n(checks metadata for a new frame)";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
            }
            
            // Workload Fragment - main processing pipeline
            subgraph cluster_workload {
                label = "Main Workload";
                style = "rounded,filled";
                fillcolor = "#f0f0f0";
                color = "#76B900";
                penwidth = "1";
                fontsize = "10";
                
                FrameSourceOp [label = "FrameSourceOpGR";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
                CsiToBayer [label = "CsiToBayerGpuResidentOp";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
                ImageProcessor [label = "ImageProcessorGpuResidentOp";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
                Demosaic [label = "BayerDemosaicGpuResidentOp";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
                DisplayOp [label = "DisplayGpuResidentOp\n(cuDisp)";fillcolor = "#76B900";color = "#ffffff";fontcolor = "#ffffff";];
                
                FrameSourceOp -> CsiToBayer;
                CsiToBayer -> ImageProcessor;
                ImageProcessor -> Demosaic;
                Demosaic -> DisplayOp;
            }
            
            // Data ready triggers workload
            DataReadyInputOp -> FrameSourceOp [label = " triggers at new frame"; style = "dashed"; color = "#76B900"; fontsize = "11";];
        }
    }
    
    // Force CPU cluster to left of GPU cluster by aligning nodes at same ranks
    subgraph {
        rank = same;
        RoceReceiverOp;
        DataReadyInputOp;
    }
    subgraph {
        rank = same;
        PresentThread;
        DisplayOp;
    }
    
    // RoceReceiverOp shares initial frame address with Data Ready Fragment (at initialization)
    RoceReceiverOp -> DataReadyInputOp [label = <<b>frame memory address<br/>(at initialization)</b>>; style = "solid"; color = "#76B900"; penwidth = "5"; fontsize = "9"; constraint = false;];
    
    // cuDisp on GPU signals present thread on CPU to trigger flip
    DisplayOp -> PresentThread [style = "dashed"; color = "#76B900"; penwidth = "1"; label = "display flip trigger"; fontsize = "11"; constraint = false;];
}