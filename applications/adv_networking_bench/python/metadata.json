				"0.6.0"
			]
		},
		"ranking": 1,
		"requirements": {
			"libraries": [{
				"name": "DAQIRI",
				"version": "0.1.0",
				"url": "https://github.com/NVIDIA/daqiri"
			}]
		},
		"run": {
			"command": "python3 <holohub_app_source>/main.py",
			"workdir": "holohub_app_bin"
		}
