{
	"application": {
		"name": "Advanced Networking Benchmark",
		"authors": [
			{
				"name": "Cliff Burdick",
				"affiliation": "NVIDIA"
			}
		],
		"language": "Python",
		"version": "1.1",
		"changelog": {
			"1.1": "Port networking backend to DAQIRI",
			"1.0": "Initial Release"
		},
		"platforms": ["x86_64", "aarch64"],
		"tags": ["Networking and Distributed Computing", "Distributed", "UDP", "GPUDirect", "DPDK"],
		"dockerfile": "pkg/holoscan-networking/Dockerfile",
		"holoscan_sdk": {
			"minimum_required_version": "0.6.0",
