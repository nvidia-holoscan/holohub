{
	"application": {
		"name": "Basic Pulse Description Word (PDW) Generator",
		"authors": [
			{
				"name": "Joshua Anderson",
				"affiliation": "GTRI"
			},
			{
				"name": "Christopher Jones",
				"affiliation": "GTRI"
			}
		],
		"language": "C++",
		"version": "1.1",
