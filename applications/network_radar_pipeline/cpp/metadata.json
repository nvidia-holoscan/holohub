{
	"application": {
		"name": "Radar Signal Processing over Network",
		"authors": [
			{
				"name": "Dylan Eustice",
				"affiliation": "NVIDIA"
			}
		],
		"language": "C++",
		"version": "1.2",
		"changelog": {
			"1.0": "Initial Release",
			"1.1": "Update networking data path",
			"1.2": "Port networking backend to DAQIRI"
		},
		"holoscan_sdk": {
			"minimum_required_version": "0.6.0",
			"tested_versions": [
				"0.6.0"
			]
		},
		"platforms": ["x86_64", "aarch64"],
		"tags": ["Signal Processing", "Networking and Distributed Computing", "GPUDirect", "DPDK"],
		"dockerfile": "pkg/holoscan-networking/Dockerfile",
		"ranking": 2,
		"requirements": {
			"libraries": [{
			  "name": "MatX",
			  "version": "0.6.0",
			  "url": "https://github.com/NVIDIA/MatX.git"
			}, {
			  "name": "DAQIRI",
			  "version": "0.1.0",
			  "url": "https://github.com/NVIDIA/daqiri"
			}]
		},
		"run": {
			"command": "<holohub_app_bin>/network_radar_pipeline",
			"workdir": "holohub_bin"
		}
	}
}
